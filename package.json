{
  "name": "bubblebytes",
  "version": "1.0.0",
  "description": "Laundry management REST API (Node.js port)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:test": "cross-env NODE_ENV=test sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "test": "cross-env NODE_ENV=test node tests/scripts/runJestWithLog.js",
    "test:security": "cross-env NODE_ENV=test node tests/scripts/runJestWithLog.js tests/security",
    "test:integration": "cross-env NODE_ENV=test node tests/scripts/runJestWithLog.js tests/integration",
    "test:concurrency": "cross-env NODE_ENV=test node tests/scripts/runJestWithLog.js tests/concurrency",
    "test:all": "node scripts/run-all-tests.js",
    "benchmark:setup": "node benchmark/scripts/setup-db.js",
    "benchmark:seed": "cross-env NODE_ENV=benchmark node benchmark/scripts/seed/seed.js",
    "benchmark:queries": "cross-env NODE_ENV=benchmark node benchmark/scripts/queries/explain-analyze.js",
    "benchmark:load": "k6 run benchmark/scripts/load/endpoints.js",
    "benchmark:concurrency": "k6 run benchmark/scripts/load/concurrency.js",
    "benchmark:capacity": "cross-env NODE_ENV=benchmark node benchmark/scripts/load/run-capacity-probe.js",
    "benchmark:db-metrics": "cross-env NODE_ENV=benchmark node benchmark/scripts/db-metrics/collect.js",
    "benchmark:profile": "cross-env NODE_ENV=benchmark node benchmark/scripts/profiling/run-profiling.js",
    "benchmark:failure": "cross-env NODE_ENV=benchmark node benchmark/scripts/failure/scenarios.js",
    "benchmark:race": "cross-env NODE_ENV=benchmark node benchmark/scripts/race/run-race.js",
    "benchmark:reports": "node benchmark/scripts/reports/generate-all.js",
    "benchmark:all": "cross-env NODE_ENV=benchmark node benchmark/scripts/run-all.js",
    "benchmark:all:quick": "cross-env NODE_ENV=benchmark node benchmark/scripts/run-all.js --skip-seed --quick",
    "benchmark:all:capacity": "cross-env NODE_ENV=benchmark node benchmark/scripts/run-all.js --skip-seed --full-load"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.12.0",
    "sequelize": "^6.37.5",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^2.3.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.0.0",
    "swagger-parser": "^10.0.3"
  }
}
